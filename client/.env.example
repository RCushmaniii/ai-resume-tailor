# --- Public client-side keys (shipped in the JS bundle; safe to commit real values) ---
VITE_API_URL=http://localhost:5000/api
VITE_GUEST_CREDITS_TOTAL=3

# Clerk authentication (REQUIRED — production build fails without it)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key

# Stripe payments (publishable key only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Sentry error reporting (DSN is public)
VITE_SENTRY_DSN=

# Set to "true" only to enable Mock Service Worker in local dev
VITE_ENABLE_MSW=false
